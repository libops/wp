.env*
certs/*
!certs/.gitignore
secrets/*
!secrets/.gitignore
docker-compose.override.yml
docker-compose.override.yaml
backups/
acme.json
vendor/
web/wp/
web/app/uploads/

# Composer exclusively owns installer destinations. Keep local package sources
# under packages/ and let Composer copy them into web/app.
/web/app/mu-plugins/*
!/web/app/mu-plugins/.gitkeep
/web/app/plugins/*
!/web/app/plugins/.gitkeep
/web/app/themes/*
!/web/app/themes/.gitkeep

# Package source is tracked, but package-local dependency and VCS state is not.
/packages/*/.git/
/packages/*/vendor/
/packages/*/node_modules/
