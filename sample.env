# Copy this file to `.env` and edit the values for your environment.

# Base HTTP hostname for the site.
# The default stack uses `localhost` if this is left unset, but setting it
# explicitly keeps the generated WordPress URLs and Traefik host rule aligned.
DOMAIN=localhost

# Required only when running with `docker-compose.tls.yml`.
# Use an address that should receive Let's Encrypt expiry/account notices.
ACME_EMAIL=admin@example.com
